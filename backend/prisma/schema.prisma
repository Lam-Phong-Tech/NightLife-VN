generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  PARTNER
  OPERATOR
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum UserTier {
  FREE
  MEMBER
  PREMIUM
  VIP
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum GuestStatus {
  ACTIVE
  CONVERTED
  BLOCKED
  DELETED
}

enum PartnerAccountStatus {
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  CLOSED
  DELETED
}

enum StoreCategory {
  BAR
  CLUB
  LOUNGE
  GIRLS_BAR
  KARAOKE
  MASSAGE_SPA
  RESTAURANT
  CASINO
}

enum AreaStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum ProfileStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum StoreStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  CLOSED
  DELETED
}

enum CastStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  OFF_DUTY
  SUSPENDED
  DELETED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingQrStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum BookingChangeRequestType {
  RESCHEDULE
}

enum BookingChangeRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum BookingChatSenderType {
  GUEST
  MEMBER
  ADMIN
  OPERATOR
  SYSTEM
}

enum BookingChatTopic {
  GENERAL
  RESCHEDULE
  CANCEL
}

enum CouponStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
  DELETED
}

enum CouponIssueStatus {
  ISSUED
  USED
  EXPIRED
  REVOKED
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum BillStatus {
  DRAFT
  SUBMITTED
  PENDING_PM_BA
  VERIFIED
  REJECTED
  PAID
  VOIDED
}

enum CommissionStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CommissionType {
  PERCENT
  FIXED_AMOUNT
}

enum PointLedgerType {
  EARN
  REDEEM
  ADJUST
  REVERSE
  EXPIRE
}

enum PointLedgerStatus {
  PENDING
  POSTED
  REVERSED
  EXPIRED
}

enum MediaStatus {
  UPLOADING
  READY
  HIDDEN
  DELETED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

enum MediaAccess {
  PUBLIC
  PROTECTED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DELETED
}

enum ContentType {
  BLOG
  STORE_POST
  BANNER
  POLICY
  FAQ
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
  ZALO
  TELEGRAM
  LINE
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  CANCELLED
}

enum PartnerRequestStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RankingTargetType {
  STORE
  CAST
  COUPON
  CONTENT
}

enum RankingConfigStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DELETED
}

model User {
  id                            String                 @id @default(uuid()) @db.Uuid
  email                         String                 @unique
  passwordHash                  String                 @map("password_hash")
  displayName                   String?                @map("display_name")
  phone                         String?
  role                          UserRole               @default(USER)
  tier                          UserTier               @default(FREE)
  status                        UserStatus             @default(ACTIVE)
  profile                       Profile?
  roleAssignments               UserRoleAssignment[]
  ownedStores                   Store[]                @relation("StoreOwner")
  partnerAccounts               PartnerAccount[]
  convertedGuests               Guest[]                @relation("GuestConvertedUser")
  casts                         Cast[]
  bookings                      Booking[]
  bills                         Bill[]
  reviewedBills                 Bill[]                 @relation("BillReviewer")
  verifiedBills                 Bill[]                 @relation("BillVerifier")
  rejectedBills                 Bill[]                 @relation("BillRejecter")
  submittedBills                Bill[]                 @relation("BillSubmitter")
  pointLedgers                  PointLedger[]
  couponIssues                  CouponIssue[]          @relation("CouponIssueUser")
  issuedCoupons                 CouponIssue[]          @relation("CouponIssueIssuer")
  scannedCoupons                CouponIssue[]          @relation("CouponIssueScanner")
  adminCouponIssues             AdminCouponIssue[]     @relation("AdminCouponIssueUser")
  scannedAdminCoupons           AdminCouponIssue[]     @relation("AdminCouponIssueScanner")
  media                         Media[]                @relation("MediaOwner")
  contents                      Content[]
  notifications                 NotificationLog[]
  submittedPartnerRequests      PartnerRequest[]       @relation("PartnerRequestPartnerUser")
  reviewedPartnerRequests       PartnerRequest[]       @relation("PartnerRequestReviewer")
  bookingChangeRequests         BookingChangeRequest[] @relation("BookingChangeRequester")
  reviewedBookingChangeRequests BookingChangeRequest[] @relation("BookingChangeReviewer")
  bookingChatMessages           BookingChatMessage[]   @relation("BookingChatSender")
  commissionConfig              CommissionConfig[]
  rankingConfigs                RankingConfig[]
  auditLogs                     AuditLog[]             @relation("AuditLogActor")
  revokedTokens                 TokenBlacklist[]
  sessions                      UserSession[]
  passwordResetTokens           PasswordResetToken[]
  storePermissions              StorePermission[]
  favoriteCasts                 MemberFavoriteCast[]
  supportTicketsUser            SupportTicket[]        @relation("SupportTicketUser")
  supportTicketsAdmin           SupportTicket[]        @relation("SupportTicketAdmin")
  supportMessages               SupportMessage[]       @relation("SupportMessageSender")
  createdAt                     DateTime               @default(now()) @map("created_at")
  updatedAt                     DateTime               @updatedAt @map("updated_at")
  deletedAt                     DateTime?              @map("deleted_at")

  @@index([status])
  @@map("users")
}

model Guest {
  id                    String                 @id @default(uuid()) @db.Uuid
  convertedUserId       String?                @map("converted_user_id") @db.Uuid
  convertedUser         User?                  @relation("GuestConvertedUser", fields: [convertedUserId], references: [id], onDelete: SetNull)
  displayName           String?                @map("display_name")
  phone                 String?
  email                 String
  note                  String?
  status                GuestStatus            @default(ACTIVE)
  bookings              Booking[]
  bills                 Bill[]
  couponIssues          CouponIssue[]
  adminCouponIssues     AdminCouponIssue[]
  notifications         NotificationLog[]
  bookingChangeRequests BookingChangeRequest[]
  bookingChatMessages   BookingChatMessage[]
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  deletedAt             DateTime?              @map("deleted_at")

  @@index([convertedUserId])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@map("guests")
}

model Profile {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @unique @map("user_id") @db.Uuid
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  fullName      String?       @map("full_name")
  gender        String?
  birthday      DateTime?
  avatarMediaId String?       @map("avatar_media_id") @db.Uuid
  avatar        Media?        @relation("ProfileAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)
  bio           String?
  status        ProfileStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  @@index([status])
  @@map("profiles")
}

model Role {
  id          String               @id @default(uuid()) @db.Uuid
  key         String               @unique
  name        String
  description String?
  level       Int                  @default(0)
  status      RoleStatus           @default(ACTIVE)
  users       UserRoleAssignment[]
  permissions RolePermission[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  @@index([status])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  name        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_role_assignments")
}

model PartnerAccount {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  user            User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  businessName    String               @map("business_name")
  legalName       String?              @map("legal_name")
  taxCode         String?              @map("tax_code")
  contactName     String?              @map("contact_name")
  contactPhone    String?              @map("contact_phone")
  contactEmail    String?              @map("contact_email")
  bankInfo        Json?                @map("bank_info")
  contractNumber  String?              @map("contract_number")
  status          PartnerAccountStatus @default(PENDING_REVIEW)
  stores          Store[]
  partnerRequests PartnerRequest[]
  bookingQrs      BookingQr[]
  submittedBills  Bill[]               @relation("BillSubmitterPartner")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")

  @@index([userId])
  @@index([status])
  @@map("partner_accounts")
}

model Area {
  id             String          @id @default(uuid()) @db.Uuid
  code           String          @unique
  name           String
  city           String          @default("Ho Chi Minh City")
  district       String?
  ward           String?
  status         AreaStatus      @default(ACTIVE)
  stores         Store[]
  rankingConfigs RankingConfig[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  @@index([city, district, ward])
  @@index([status])
  @@map("areas")
}

model Store {
  id                         String                 @id @default(uuid()) @db.Uuid
  ownerId                    String?                @map("owner_id") @db.Uuid
  partnerAccountId           String?                @map("partner_account_id") @db.Uuid
  areaId                     String?                @map("area_id") @db.Uuid
  owner                      User?                  @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  partnerAccount             PartnerAccount?        @relation(fields: [partnerAccountId], references: [id], onDelete: SetNull)
  area                       Area?                  @relation(fields: [areaId], references: [id], onDelete: SetNull)
  name                       String
  slug                       String                 @unique
  category                   StoreCategory
  description                String?
  address                    String?
  city                       String                 @default("Ho Chi Minh City")
  district                   String?
  phone                      String?
  latitude                   Decimal?               @db.Decimal(10, 7)
  longitude                  Decimal?               @db.Decimal(10, 7)
  openingHours               Json?                  @map("opening_hours")
  holidaySchedule            Json?                  @map("holiday_schedule")
  pricingInfo                Json?                  @map("pricing_info")
  staffProfileInfo           Json?                  @map("staff_profile_info")
  supportedLanguages         String[]               @default([]) @map("supported_languages")
  seoTitle                   String?                @map("seo_title")
  seoDescription             String?                @map("seo_description")
  bookingCancelCutoffMinutes Int                    @default(60) @map("booking_cancel_cutoff_minutes")
  mapUrl                     String?                @map("map_url")
  googlePlaceId              String?                @map("google_place_id")
  status                     StoreStatus            @default(DRAFT)
  tags                       String[]               @default([])
  casts                      Cast[]
  bookings                   Booking[]
  bookingQrs                 BookingQr[]
  coupons                    Coupon[]
  adminCouponIssues          AdminCouponIssue[]
  bills                      Bill[]
  commissionConfigs          CommissionConfig[]
  media                      Media[]
  contents                   Content[]
  notifications              NotificationLog[]
  partnerRequests            PartnerRequest[]
  bookingChangeRequests      BookingChangeRequest[]
  bookingChatMessages        BookingChatMessage[]
  userPermissions            StorePermission[]
  createdAt                  DateTime               @default(now()) @map("created_at")
  updatedAt                  DateTime               @updatedAt @map("updated_at")
  deletedAt                  DateTime?              @map("deleted_at")

  @@index([ownerId])
  @@index([partnerAccountId])
  @@index([areaId])
  @@index([category])
  @@index([status])
  @@index([city, district])
  @@map("stores")
}

model Cast {
  id                    String                 @id @default(uuid()) @db.Uuid
  storeId               String                 @map("store_id") @db.Uuid
  userId                String?                @map("user_id") @db.Uuid
  store                 Store                  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  stageName             String                 @map("stage_name")
  slug                  String                 @unique
  bio                   String?
  publicAlias           String?                @map("public_alias")
  publicHeadline        String?                @map("public_headline")
  publicBio             String?                @map("public_bio")
  tags                  String[]               @default([])
  youtubeLinks          String[]               @default([]) @map("youtube_links")
  languages             String[]               @default([])
  birthMonth            Int?                   @map("birth_month")
  zodiacSign            String?                @map("zodiac_sign")
  heightCm              Int?                   @map("height_cm")
  measurements          String?
  hobbies               String[]               @default([])
  styleTags             String[]               @default([]) @map("style_tags")
  isPublic              Boolean                @default(true) @map("is_public")
  hourlyRateVnd         Int?                   @map("hourly_rate_vnd")
  status                CastStatus             @default(DRAFT)
  bookings              Booking[]
  bookingChangeRequests BookingChangeRequest[]
  media                 Media[]
  memberFavorites       MemberFavoriteCast[]
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  deletedAt             DateTime?              @map("deleted_at")

  @@index([storeId])
  @@index([userId])
  @@index([status])
  @@map("casts")
}

model MemberFavoriteCast {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  castId    String   @map("cast_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cast      Cast     @relation(fields: [castId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, castId])
  @@index([userId])
  @@index([castId])
  @@map("member_favorite_casts")
}

model Booking {
  id                     String                 @id @default(uuid()) @db.Uuid
  bookingCode            String                 @unique @map("booking_code") @db.VarChar(15)
  userId                 String?                @map("user_id") @db.Uuid
  guestId                String?                @map("guest_id") @db.Uuid
  storeId                String                 @map("store_id") @db.Uuid
  castId                 String?                @map("cast_id") @db.Uuid
  couponId               String?                @map("coupon_id") @db.Uuid
  couponIssueId          String?                @unique @map("coupon_issue_id") @db.Uuid
  user                   User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  guest                  Guest?                 @relation(fields: [guestId], references: [id], onDelete: SetNull)
  store                  Store                  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  cast                   Cast?                  @relation(fields: [castId], references: [id], onDelete: SetNull)
  coupon                 Coupon?                @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponIssue            CouponIssue?           @relation("BookingCouponIssue", fields: [couponIssueId], references: [id], onDelete: SetNull)
  bill                   Bill?
  pointLedgers           PointLedger[]
  notifications          NotificationLog[]
  changeRequests         BookingChangeRequest[]
  chatMessages           BookingChatMessage[]
  media                  Media[]
  qr                     BookingQr?
  status                 BookingStatus          @default(REQUESTED)
  scheduledAt            DateTime               @map("scheduled_at")
  partySize              Int                    @default(1) @map("party_size")
  note                   String?
  subtotalVnd            Int                    @default(0) @map("subtotal_vnd")
  discountVnd            Int                    @default(0) @map("discount_vnd")
  totalVnd               Int                    @default(0) @map("total_vnd")
  discountSnapshot       Json?                  @map("discount_rule_snapshot")
  commissionRuleSnapshot Json?                  @map("commission_rule_snapshot")
  pointRuleSnapshot      Json?                  @map("point_rule_snapshot")
  cancelReason           String?                @map("cancel_reason")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  cancelledAt            DateTime?              @map("cancelled_at")
  deletedAt              DateTime?              @map("deleted_at")

  @@index([userId])
  @@index([guestId])
  @@index([storeId])
  @@index([castId])
  @@index([couponId])
  @@index([status])
  @@index([scheduledAt])
  @@map("bookings")
}

model BookingQr {
  id                        String          @id @default(uuid()) @db.Uuid
  bookingId                 String          @unique @map("booking_id") @db.Uuid
  storeId                   String          @map("store_id") @db.Uuid
  code                      String          @unique
  qrPayloadHash             String          @unique @map("qr_payload_hash")
  discountSnapshot          Json            @map("discount_snapshot")
  validFrom                 DateTime        @map("valid_from")
  expiresAt                 DateTime        @map("expires_at")
  status                    BookingQrStatus @default(ACTIVE)
  usedAt                    DateTime?       @map("used_at")
  scannedByPartnerAccountId String?         @map("scanned_by_partner_account_id") @db.Uuid
  revokedAt                 DateTime?       @map("revoked_at")
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  booking                 Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  store                   Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  scannedByPartnerAccount PartnerAccount? @relation(fields: [scannedByPartnerAccountId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([scannedByPartnerAccountId])
  @@index([status])
  @@map("booking_qrs")
}

model BookingChangeRequest {
  id                   String                     @id @default(uuid()) @db.Uuid
  bookingId            String                     @map("booking_id") @db.Uuid
  storeId              String                     @map("store_id") @db.Uuid
  castId               String?                    @map("cast_id") @db.Uuid
  requestedById        String?                    @map("requested_by_id") @db.Uuid
  guestId              String?                    @map("guest_id") @db.Uuid
  reviewedById         String?                    @map("reviewed_by_id") @db.Uuid
  type                 BookingChangeRequestType   @default(RESCHEDULE)
  status               BookingChangeRequestStatus @default(REQUESTED)
  currentScheduledAt   DateTime                   @map("current_scheduled_at")
  requestedScheduledAt DateTime?                  @map("requested_scheduled_at")
  reason               String?
  adminNote            String?                    @map("admin_note")
  reviewedAt           DateTime?                  @map("reviewed_at")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")
  booking              Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  store                Store                      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  cast                 Cast?                      @relation(fields: [castId], references: [id], onDelete: SetNull)
  requestedBy          User?                      @relation("BookingChangeRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  guest                Guest?                     @relation(fields: [guestId], references: [id], onDelete: SetNull)
  reviewedBy           User?                      @relation("BookingChangeReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  messages             BookingChatMessage[]

  @@index([bookingId])
  @@index([storeId])
  @@index([castId])
  @@index([requestedById])
  @@index([guestId])
  @@index([reviewedById])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("booking_change_requests")
}

model BookingChatMessage {
  id              String                @id @default(uuid()) @db.Uuid
  bookingId       String                @map("booking_id") @db.Uuid
  changeRequestId String?               @map("change_request_id") @db.Uuid
  storeId         String                @map("store_id") @db.Uuid
  senderUserId    String?               @map("sender_user_id") @db.Uuid
  guestId         String?               @map("guest_id") @db.Uuid
  senderType      BookingChatSenderType @map("sender_type")
  topic           BookingChatTopic      @default(GENERAL)
  body            String
  createdAt       DateTime              @default(now()) @map("created_at")
  booking         Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changeRequest   BookingChangeRequest? @relation(fields: [changeRequestId], references: [id], onDelete: SetNull)
  store           Store                 @relation(fields: [storeId], references: [id], onDelete: Restrict)
  senderUser      User?                 @relation("BookingChatSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  guest           Guest?                @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([changeRequestId])
  @@index([storeId])
  @@index([senderUserId])
  @@index([guestId])
  @@index([topic])
  @@index([createdAt])
  @@map("booking_chat_messages")
}

model Coupon {
  id             String        @id @default(uuid()) @db.Uuid
  storeId        String        @map("store_id") @db.Uuid
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  code           String        @unique
  name           String
  description    String?
  discountType   DiscountType  @map("discount_type")
  discountValue  Int           @map("discount_value")
  maxDiscountVnd Int?          @map("max_discount_vnd")
  minSpendVnd    Int?          @map("min_spend_vnd")
  usageLimit     Int?          @map("usage_limit")
  usedCount      Int           @default(0) @map("used_count")
  startsAt       DateTime      @map("starts_at")
  endsAt         DateTime?     @map("ends_at")
  status         CouponStatus  @default(DRAFT)
  bookings       Booking[]
  bills          Bill[]
  issues         CouponIssue[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  @@index([storeId])
  @@index([status])
  @@index([startsAt, endsAt])
  @@map("coupons")
}

model CouponIssue {
  id            String            @id @default(uuid()) @db.Uuid
  couponId      String            @map("coupon_id") @db.Uuid
  userId        String?           @map("user_id") @db.Uuid
  guestId       String?           @map("guest_id") @db.Uuid
  issuedById    String?           @map("issued_by_id") @db.Uuid
  scannedById   String?           @map("scanned_by_id") @db.Uuid
  coupon        Coupon            @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user          User?             @relation("CouponIssueUser", fields: [userId], references: [id], onDelete: SetNull)
