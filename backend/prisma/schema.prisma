generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  PARTNER
  OPERATOR
  STAFF
  ADMIN
}

enum UserTier {
  FREE
  PREMIUM
  VIP
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum GuestStatus {
  ACTIVE
  CONVERTED
  BLOCKED
  DELETED
}

enum PartnerAccountStatus {
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  CLOSED
  DELETED
}

enum StoreCategory {
  BAR
  CLUB
  LOUNGE
  GIRLS_BAR
  KARAOKE
  MASSAGE_SPA
  RESTAURANT
  CASINO
}

enum AreaStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum ProfileStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum StoreStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  CLOSED
  DELETED
}

enum CastStatus {
  DRAFT
  ACTIVE
  OFF_DUTY
  SUSPENDED
  DELETED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CouponStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
  DELETED
}

enum CouponIssueStatus {
  ISSUED
  USED
  EXPIRED
  REVOKED
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum BillStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
  PAID
  VOIDED
}

enum CommissionStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CommissionType {
  PERCENT
  FIXED_AMOUNT
}

enum PointLedgerType {
  EARN
  REDEEM
  ADJUST
  REVERSE
  EXPIRE
}

enum PointLedgerStatus {
  PENDING
  POSTED
  REVERSED
  EXPIRED
}

enum MediaStatus {
  UPLOADING
  READY
  HIDDEN
  DELETED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

enum MediaAccess {
  PUBLIC
  PROTECTED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DELETED
}

enum ContentType {
  BLOG
  STORE_POST
  BANNER
  POLICY
  FAQ
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
  ZALO
  TELEGRAM
  LINE
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  CANCELLED
}

enum RankingTargetType {
  STORE
  CAST
  COUPON
  CONTENT
}

enum RankingConfigStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DELETED
}

model User {
  id               String               @id @default(uuid()) @db.Uuid
  email            String               @unique
  passwordHash     String               @map("password_hash")
  displayName      String?              @map("display_name")
  phone            String?
  role             UserRole             @default(USER)
  tier             UserTier             @default(FREE)
  status           UserStatus           @default(ACTIVE)
  profile          Profile?
  roleAssignments  UserRoleAssignment[]
  ownedStores      Store[]              @relation("StoreOwner")
  partnerAccounts  PartnerAccount[]
  convertedGuests  Guest[]              @relation("GuestConvertedUser")
  casts            Cast[]
  bookings         Booking[]
  bills            Bill[]
  reviewedBills    Bill[]               @relation("BillReviewer")
  verifiedBills    Bill[]               @relation("BillVerifier")
  rejectedBills    Bill[]               @relation("BillRejecter")
  pointLedgers     PointLedger[]
  couponIssues     CouponIssue[]        @relation("CouponIssueUser")
  issuedCoupons    CouponIssue[]        @relation("CouponIssueIssuer")
  scannedCoupons   CouponIssue[]        @relation("CouponIssueScanner")
  media            Media[]              @relation("MediaOwner")
  contents         Content[]
  notifications    NotificationLog[]
  commissionConfig CommissionConfig[]
  rankingConfigs   RankingConfig[]
  auditLogs        AuditLog[]           @relation("AuditLogActor")
  revokedTokens    TokenBlacklist[]
  sessions         UserSession[]
  storePermissions StorePermission[]
  favoriteCasts    MemberFavoriteCast[]
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  deletedAt        DateTime?            @map("deleted_at")

  @@index([status])
  @@map("users")
}

model Guest {
  id              String            @id @default(uuid()) @db.Uuid
  convertedUserId String?           @map("converted_user_id") @db.Uuid
  convertedUser   User?             @relation("GuestConvertedUser", fields: [convertedUserId], references: [id], onDelete: SetNull)
  displayName     String?           @map("display_name")
  phone           String?
  email           String?
  note            String?
  status          GuestStatus       @default(ACTIVE)
  bookings        Booking[]
  bills           Bill[]
  couponIssues    CouponIssue[]
  notifications   NotificationLog[]
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  @@index([convertedUserId])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@map("guests")
}

model Profile {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @unique @map("user_id") @db.Uuid
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  fullName      String?       @map("full_name")
  gender        String?
  birthday      DateTime?
  avatarMediaId String?       @map("avatar_media_id") @db.Uuid
  avatar        Media?        @relation("ProfileAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)
  bio           String?
  status        ProfileStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  @@index([status])
  @@map("profiles")
}

model Role {
  id          String               @id @default(uuid()) @db.Uuid
  key         String               @unique
  name        String
  description String?
  status      RoleStatus           @default(ACTIVE)
  users       UserRoleAssignment[]
  permissions RolePermission[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  @@index([status])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  name        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_role_assignments")
}

model PartnerAccount {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  user           User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  businessName   String               @map("business_name")
  legalName      String?              @map("legal_name")
  taxCode        String?              @map("tax_code")
  contactName    String?              @map("contact_name")
  contactPhone   String?              @map("contact_phone")
  contactEmail   String?              @map("contact_email")
  bankInfo       Json?                @map("bank_info")
  contractNumber String?              @map("contract_number")
  status         PartnerAccountStatus @default(PENDING_REVIEW)
  stores         Store[]
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")

  @@index([userId])
  @@index([status])
  @@map("partner_accounts")
}

model Area {
  id        String     @id @default(uuid()) @db.Uuid
  code      String     @unique
  name      String
  city      String     @default("Ho Chi Minh City")
  district  String?
  ward      String?
  status    AreaStatus @default(ACTIVE)
  stores    Store[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  @@index([city, district, ward])
  @@index([status])
  @@map("areas")
}

model Store {
  id                String             @id @default(uuid()) @db.Uuid
  ownerId           String?            @map("owner_id") @db.Uuid
  partnerAccountId  String?            @map("partner_account_id") @db.Uuid
  areaId            String?            @map("area_id") @db.Uuid
  owner             User?              @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  partnerAccount    PartnerAccount?    @relation(fields: [partnerAccountId], references: [id], onDelete: SetNull)
  area              Area?              @relation(fields: [areaId], references: [id], onDelete: SetNull)
  name              String
  slug              String             @unique
  category          StoreCategory
  description       String?
  address           String?
  city              String             @default("Ho Chi Minh City")
  district          String?
  phone             String?
  latitude          Decimal?           @db.Decimal(10, 7)
  longitude         Decimal?           @db.Decimal(10, 7)
  openingHours      Json?              @map("opening_hours")
  holidaySchedule   Json?              @map("holiday_schedule")
  mapUrl            String?            @map("map_url")
  googlePlaceId     String?            @map("google_place_id")
  status            StoreStatus        @default(DRAFT)
  casts             Cast[]
  bookings          Booking[]
  coupons           Coupon[]
  bills             Bill[]
  commissionConfigs CommissionConfig[]
  media             Media[]
  contents          Content[]
  notifications     NotificationLog[]
  userPermissions   StorePermission[]
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  @@index([ownerId])
  @@index([partnerAccountId])
  @@index([areaId])
  @@index([category])
  @@index([status])
  @@index([city, district])
  @@map("stores")
}

model Cast {
  id             String     @id @default(uuid()) @db.Uuid
  storeId        String     @map("store_id") @db.Uuid
  userId         String?    @map("user_id") @db.Uuid
  store          Store      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  stageName      String     @map("stage_name")
  slug           String     @unique
  bio            String?
  publicAlias    String?    @map("public_alias")
  publicHeadline String?    @map("public_headline")
  publicBio      String?    @map("public_bio")
  tags           String[]   @default([])
  languages      String[]   @default([])
  isPublic       Boolean    @default(true) @map("is_public")
  hourlyRateVnd  Int?       @map("hourly_rate_vnd")
  status         CastStatus @default(DRAFT)
  bookings       Booking[]
  media          Media[]
  memberFavorites MemberFavoriteCast[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  @@index([storeId])
  @@index([userId])
  @@index([status])
  @@map("casts")
}

model MemberFavoriteCast {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  castId    String   @map("cast_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cast      Cast     @relation(fields: [castId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, castId])
  @@index([userId])
  @@index([castId])
  @@map("member_favorite_casts")
}

model Booking {
  id                     String            @id @default(uuid()) @db.Uuid
  userId                 String?           @map("user_id") @db.Uuid
  guestId                String?           @map("guest_id") @db.Uuid
  storeId                String            @map("store_id") @db.Uuid
  castId                 String?           @map("cast_id") @db.Uuid
  couponId               String?           @map("coupon_id") @db.Uuid
  couponIssueId          String?           @unique @map("coupon_issue_id") @db.Uuid
  user                   User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  guest                  Guest?            @relation(fields: [guestId], references: [id], onDelete: SetNull)
  store                  Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  cast                   Cast?             @relation(fields: [castId], references: [id], onDelete: SetNull)
  coupon                 Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponIssue            CouponIssue?      @relation("BookingCouponIssue", fields: [couponIssueId], references: [id], onDelete: SetNull)
  bill                   Bill?
  pointLedgers           PointLedger[]
  notifications          NotificationLog[]
  media                  Media[]
  status                 BookingStatus     @default(REQUESTED)
  scheduledAt            DateTime          @map("scheduled_at")
  partySize              Int               @default(1) @map("party_size")
  note                   String?
  subtotalVnd            Int               @default(0) @map("subtotal_vnd")
  discountVnd            Int               @default(0) @map("discount_vnd")
  totalVnd               Int               @default(0) @map("total_vnd")
  discountRuleSnapshot   Json?             @map("discount_rule_snapshot")
  commissionRuleSnapshot Json?             @map("commission_rule_snapshot")
  pointRuleSnapshot      Json?             @map("point_rule_snapshot")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  cancelledAt            DateTime?         @map("cancelled_at")
  deletedAt              DateTime?         @map("deleted_at")

  @@index([userId])
  @@index([guestId])
  @@index([storeId])
  @@index([castId])
  @@index([couponId])
  @@index([status])
  @@index([scheduledAt])
  @@map("bookings")
}

model Coupon {
  id             String        @id @default(uuid()) @db.Uuid
  storeId        String        @map("store_id") @db.Uuid
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  code           String        @unique
  name           String
  description    String?
  discountType   DiscountType  @map("discount_type")
  discountValue  Int           @map("discount_value")
  maxDiscountVnd Int?          @map("max_discount_vnd")
  minSpendVnd    Int?          @map("min_spend_vnd")
  usageLimit     Int?          @map("usage_limit")
  usedCount      Int           @default(0) @map("used_count")
  startsAt       DateTime      @map("starts_at")
  endsAt         DateTime?     @map("ends_at")
  status         CouponStatus  @default(DRAFT)
  bookings       Booking[]
  bills          Bill[]
  issues         CouponIssue[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  @@index([storeId])
  @@index([status])
  @@index([startsAt, endsAt])
  @@map("coupons")
}

model CouponIssue {
  id            String            @id @default(uuid()) @db.Uuid
  couponId      String            @map("coupon_id") @db.Uuid
  userId        String?           @map("user_id") @db.Uuid
  guestId       String?           @map("guest_id") @db.Uuid
  issuedById    String?           @map("issued_by_id") @db.Uuid
  scannedById   String?           @map("scanned_by_id") @db.Uuid
  coupon        Coupon            @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user          User?             @relation("CouponIssueUser", fields: [userId], references: [id], onDelete: SetNull)
  guest         Guest?            @relation(fields: [guestId], references: [id], onDelete: SetNull)
  issuedBy      User?             @relation("CouponIssueIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  scannedBy     User?             @relation("CouponIssueScanner", fields: [scannedById], references: [id], onDelete: SetNull)
  booking       Booking?          @relation("BookingCouponIssue")
  bill          Bill?             @relation("BillCouponIssue")
  code          String            @unique
  qrPayloadHash String            @unique @map("qr_payload_hash")
  status        CouponIssueStatus @default(ISSUED)
  expiresAt     DateTime?         @map("expires_at")
  usedAt        DateTime?         @map("used_at")
  revokedAt     DateTime?         @map("revoked_at")
  metadata      Json?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([couponId])
  @@index([userId])
  @@index([guestId])
  @@index([issuedById])
  @@index([scannedById])
  @@index([status])
  @@map("coupon_issues")
}

model Bill {
  id                     String            @id @default(uuid()) @db.Uuid
  bookingId              String?           @unique @map("booking_id") @db.Uuid
  userId                 String?           @map("user_id") @db.Uuid
  guestId                String?           @map("guest_id") @db.Uuid
  storeId                String            @map("store_id") @db.Uuid
  couponId               String?           @map("coupon_id") @db.Uuid
  couponIssueId          String?           @unique @map("coupon_issue_id") @db.Uuid
  reviewedById           String?           @map("reviewed_by_id") @db.Uuid
  verifiedById           String?           @map("verified_by_id") @db.Uuid
  rejectedById           String?           @map("rejected_by_id") @db.Uuid
  booking                Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  user                   User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  guest                  Guest?            @relation(fields: [guestId], references: [id], onDelete: SetNull)
  store                  Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  coupon                 Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponIssue            CouponIssue?      @relation("BillCouponIssue", fields: [couponIssueId], references: [id], onDelete: SetNull)
  reviewedBy             User?             @relation("BillReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  verifiedBy             User?             @relation("BillVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  rejectedBy             User?             @relation("BillRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  pointLedgers           PointLedger[]
  media                  Media[]
  notifications          NotificationLog[]
  status                 BillStatus        @default(DRAFT)
  billNumber             String?           @unique @map("bill_number")
  subtotalVnd            Int               @default(0) @map("subtotal_vnd")
  discountVnd            Int               @default(0) @map("discount_vnd")
  serviceChargeVnd       Int               @default(0) @map("service_charge_vnd")
  taxVnd                 Int               @default(0) @map("tax_vnd")
  totalVnd               Int               @default(0) @map("total_vnd")
  paidVnd                Int               @default(0) @map("paid_vnd")
  commissionAmountVnd    Int               @default(0) @map("commission_amount_vnd")
  pointsEarned           Int               @default(0) @map("points_earned")
  discountRuleSnapshot   Json?             @map("discount_rule_snapshot")
  commissionRuleSnapshot Json?             @map("commission_rule_snapshot")
  pointRuleSnapshot      Json?             @map("point_rule_snapshot")
  submittedAt            DateTime?         @map("submitted_at")
  reviewedAt             DateTime?         @map("reviewed_at")
  verifiedAt             DateTime?         @map("verified_at")
  rejectedAt             DateTime?         @map("rejected_at")
  rejectReason           String?           @map("reject_reason")
  usedAt                 DateTime?         @map("used_at")
  paidAt                 DateTime?         @map("paid_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  deletedAt              DateTime?         @map("deleted_at")

  @@index([userId])
  @@index([guestId])
  @@index([storeId])
  @@index([couponId])
  @@index([reviewedById])
  @@index([verifiedById])
  @@index([rejectedById])
  @@index([status])
  @@map("bills")
}

model CommissionConfig {
  id              String           @id @default(uuid()) @db.Uuid
  storeId         String           @map("store_id") @db.Uuid
  createdById     String?          @map("created_by_id") @db.Uuid
  store           Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy       User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  commissionType  CommissionType   @default(PERCENT) @map("commission_type")
  commissionValue Int              @map("commission_value")
  pointEarnRate   Decimal?         @map("point_earn_rate") @db.Decimal(10, 4)
  minBillVnd      Int?             @map("min_bill_vnd")
  ruleSnapshot    Json?            @map("rule_snapshot")
  status          CommissionStatus @default(ACTIVE)
  activeFrom      DateTime         @default(now()) @map("active_from")
  activeTo        DateTime?        @map("active_to")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([createdById])
  @@index([status])
  @@map("commission_configs")
}

model PointLedger {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  bookingId        String?           @map("booking_id") @db.Uuid
  billId           String?           @map("bill_id") @db.Uuid
  reversedLedgerId String?           @map("reversed_ledger_id") @db.Uuid
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  booking          Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bill             Bill?             @relation(fields: [billId], references: [id], onDelete: SetNull)
  reversedLedger   PointLedger?      @relation("PointLedgerReversal", fields: [reversedLedgerId], references: [id], onDelete: SetNull)
  reversals        PointLedger[]     @relation("PointLedgerReversal")
  type             PointLedgerType
  status           PointLedgerStatus @default(PENDING)
  points           Int
  balanceAfter     Int?              @map("balance_after")
  description      String?
  ruleSnapshot     Json?             @map("rule_snapshot")
  expiresAt        DateTime?         @map("expires_at")
  postedAt         DateTime?         @map("posted_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([userId])
  @@index([bookingId])
  @@index([billId])
  @@index([reversedLedgerId])
  @@index([status])
  @@map("point_ledgers")
}

model Media {
  id             String      @id @default(uuid()) @db.Uuid
  ownerId        String?     @map("owner_id") @db.Uuid
  storeId        String?     @map("store_id") @db.Uuid
  castId         String?     @map("cast_id") @db.Uuid
  bookingId      String?     @map("booking_id") @db.Uuid
  billId         String?     @map("bill_id") @db.Uuid
  contentId      String?     @map("content_id") @db.Uuid
  owner          User?       @relation("MediaOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  store          Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)
  cast           Cast?       @relation(fields: [castId], references: [id], onDelete: SetNull)
  booking        Booking?    @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bill           Bill?       @relation(fields: [billId], references: [id], onDelete: SetNull)
  content        Content?    @relation(fields: [contentId], references: [id], onDelete: SetNull)
  profileAvatars Profile[]   @relation("ProfileAvatar")
  storageKey     String      @unique @map("storage_key")
  originalName   String      @map("original_name")
  mimeType       String      @map("mime_type")
  sizeBytes      Int         @map("size_bytes")
  url            String
  purpose        String?
  type           MediaType   @default(OTHER)
  access         MediaAccess @default(PROTECTED)
  status         MediaStatus @default(READY)
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  @@index([ownerId])
  @@index([storeId])
  @@index([castId])
  @@index([bookingId])
  @@index([billId])
  @@index([contentId])
  @@index([access])
  @@index([status])
  @@map("media_files")
}

model Content {
  id          String        @id @default(uuid()) @db.Uuid
  authorId    String?       @map("author_id") @db.Uuid
  storeId     String?       @map("store_id") @db.Uuid
  author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  store       Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  title       String
  slug        String        @unique
  type        ContentType
  status      ContentStatus @default(DRAFT)
  excerpt     String?
  body        String?
  metadata    Json?
  media       Media[]
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  @@index([authorId])
  @@index([storeId])
  @@index([type])
  @@index([status])
  @@map("contents")
}

model NotificationLog {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String?             @map("user_id") @db.Uuid
  guestId     String?             @map("guest_id") @db.Uuid
  storeId     String?             @map("store_id") @db.Uuid
  bookingId   String?             @map("booking_id") @db.Uuid
  billId      String?             @map("bill_id") @db.Uuid
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  guest       Guest?              @relation(fields: [guestId], references: [id], onDelete: SetNull)
  store       Store?              @relation(fields: [storeId], references: [id], onDelete: SetNull)
  booking     Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bill        Bill?               @relation(fields: [billId], references: [id], onDelete: SetNull)
  channel     NotificationChannel
  status      NotificationStatus  @default(QUEUED)
  recipient   String
  templateKey String?             @map("template_key")
  payload     Json?
  error       String?
  sentAt      DateTime?           @map("sent_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([userId])
  @@index([guestId])
  @@index([storeId])
  @@index([bookingId])
  @@index([billId])
  @@index([status])
  @@map("notification_logs")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metadata   Json?
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model UserSession {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti        String        @unique
  status     SessionStatus @default(ACTIVE)
  userAgent  String?       @map("user_agent")
  ipAddress  String?       @map("ip_address")
  expiresAt  DateTime      @map("expires_at")
  lastSeenAt DateTime?     @map("last_seen_at")
  revokedAt  DateTime?     @map("revoked_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("user_sessions")
}

model TokenBlacklist {
  id        String   @id @default(uuid()) @db.Uuid
  jti       String   @unique
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("token_blacklist")
}

model StorePermission {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  storeId     String     @map("store_id") @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Restrict)
  permissions String[]   @default([])
  status      RoleStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  @@unique([userId, storeId])
  @@index([storeId])
  @@index([status])
  @@map("store_permissions")
}

model RankingConfig {
  id          String              @id @default(uuid()) @db.Uuid
  createdById String?             @map("created_by_id") @db.Uuid
  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  targetType  RankingTargetType   @map("target_type")
  targetId    String              @map("target_id") @db.Uuid
  manualScore Int                 @default(0) @map("manual_score")
  pinRank     Int?                @map("pin_rank")
  reason      String?
  status      RankingConfigStatus @default(ACTIVE)
  startsAt    DateTime?           @map("starts_at")
  endsAt      DateTime?           @map("ends_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  @@index([createdById])
  @@index([targetType, targetId])
  @@index([status])
  @@map("ranking_configs")
}
