enum SupportTicketStatus {
  PENDING
  ACTIVE
  CLOSED
}

enum SupportSenderType {
  GUEST
  USER
  ADMIN
  SYSTEM
}

model SupportTicket {
  id              String              @id @default(uuid()) @db.Uuid
