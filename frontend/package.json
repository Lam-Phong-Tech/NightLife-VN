{
  "name": "nightlife-vn-frontend",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "dependencies": {
    "socket.io-client": "^4.8.3",
    "turbo": "2.9.18"
  },
  "devDependencies": {
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "approvedBuilds": [
      "esbuild",
      "core-js"
    ]
  }
}
