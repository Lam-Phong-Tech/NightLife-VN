+  private buildAdminCouponQrPayload(issueId: string) {
+    const token = this.buildSignedAdminCouponQrToken(issueId);
+    const baseUrl = this.couponQrPartnerUrl();
+    const url = new URL(baseUrl);
+    url.searchParams.set('scanToken', token);
+    return url.toString();
+  }
+
+  private buildSignedAdminCouponQrToken(issueId: string) {
+    const encodedPayload = Buffer.from(
+      JSON.stringify({
+        v: 1,
+        type: 'admin_coupon_issue',
+        issueId,
+        nonce: randomUUID(),
+        iat: Date.now(),
+      }),
+    ).toString('base64url');
+    const signature = this.signCouponQrPayload(encodedPayload);
+    return `${encodedPayload}.${signature}`;
+  }
