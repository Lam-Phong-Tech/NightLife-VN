+      );
+      if (!hasAudience) {
+        throw new UnprocessableEntityException(
+          'User tier not eligible for this coupon',
+        );
+      }
+    }
+
+    const existingIssue = await this.prisma.adminCouponIssue.findFirst({
+      where: {
+        adminCouponId: coupon.id,
+        userId: user.id,
+        status: { in: ['ISSUED', 'USED'] },
+      },
+    });
+
+    if (existingIssue) {
+      throw new UnprocessableEntityException(
+        'You have already claimed this coupon',
+      );
+    }
+
+    const recipientType = 'MEMBER';
+    const validityMs = 7 * DAY_MS;
+    const expiresAt = coupon.endsAt
+      ? new Date(Math.min(now.getTime() + validityMs, coupon.endsAt.getTime()))
+      : new Date(now.getTime() + validityMs);
+
+    const issueId = randomUUID();
+    const issueCode = `${recipientType}-${randomUUID()}`;
